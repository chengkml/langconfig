    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-opener": "^2",
    "animejs": "^4.2.2",
    "axios": "^1.15.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "html2canvas-oklch": "^1.5.0-alpha.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.25",
    "lucide-react": "^0.546.0",
    "marked": "^17.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.12.0",
