{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "start:docker": "docker-compose up -d postgres",
    "start:backend": "cd backend && uvicorn main:app --reload --port 8765",
    "start:all": "npm run start:docker && concurrently --names \"BACKEND,FRONTEND\" -c \"bgBlue,bgGreen\" \"npm run start:backend\" \"npm run dev\""
  },
  "dependencies": {
